# Copy file này thành backend_py/.env rồi điền thông tin thật của bạn.
# KHÔNG commit file .env (đã có trong .gitignore).

# Chọn nhà cung cấp LLM: anthropic | deepseek | openai_like
# (openai_like dùng cho bất kỳ provider nào có API tương thích OpenAI
# chat completions — dùng được cho cả FPT AI và NVIDIA, xem ví dụ bên dưới)
LLM_PROVIDER=openai_like

# Bắt buộc: API key thật của bạn.
LLM_API_KEY=

# Tên model theo đúng provider đã chọn ở trên.
LLM_MODEL=

# openai_like: BẮT BUỘC phải điền base URL của provider.
# deepseek: tuỳ chọn, mặc định https://api.deepseek.com nếu để trống.
LLM_BASE_URL=

LLM_MAX_TOKENS=600

# Timeout (giây) cho mỗi lời gọi LLM (áp dụng cho cả 3 provider) — mặc định
# 3s để đảm bảo tổng thời gian phản hồi < 5s. Nếu LLM chậm/treo quá thời
# gian này, hệ thống tự động fallback sang lời giải thích tạo từ dữ liệu
# thật (matched_reasons/tradeoffs) thay vì chờ LLM.
FPT_TIMEOUT_SECONDS=3

# Số sản phẩm tối đa đưa vào Top N khi ranking (mặc định 3).
DEFAULT_TOP_N=3

# ---------------------------------------------------------------------------
# RERANKER (tuỳ chọn, API-ONLY — KHÔNG tải model local)
# ---------------------------------------------------------------------------
# Cross-encoder reranker gọi qua HTTP để sắp lại thứ tự sản phẩm theo mức độ
# liên quan với nhu cầu khách. TẮT mặc định; chỉ bật khi đã điền đủ URL/MODEL/
# KEY. Mọi lỗi/timeout tự fallback về thứ tự rule-based (không treo, không chết).
#
# RERANK_ENABLED=true
# RERANK_API_URL=<endpoint rerank chuẩn Jina/Cohere: {query,documents}->{results[]}>
# RERANK_MODEL=<model id, vd jina-reranker-v2-base-multilingual / rerank-multilingual-v3.0>
# RERANK_API_KEY=<key; để trống sẽ dùng lại LLM_API_KEY>
# RERANK_TIMEOUT_SECONDS=3
# RERANK_ALPHA=0.5            # final = alpha*rule_score + (1-alpha)*rerank_score
# RERANK_CANDIDATE_POOL=20    # số ứng viên tối đa gửi lên API mỗi request
#
# Ví dụ Jina AI:  RERANK_API_URL=https://api.jina.ai/v1/rerank
# Ví dụ Cohere:   RERANK_API_URL=https://api.cohere.ai/v1/rerank
# FPT AI: dùng nếu FPT có endpoint rerank tương thích; nếu không, để RERANK_ENABLED=false.

# ---------------------------------------------------------------------------
# VÍ DỤ CẤU HÌNH THEO PROVIDER (copy đúng 4 dòng LLM_* tương ứng ở trên,
# chỉ đổi key/model/base_url — prompt và business logic giữ nguyên):
#
# FPT AI (production/competition), nếu FPT có endpoint tương thích OpenAI:
#   LLM_PROVIDER=openai_like
#   LLM_API_KEY=<FPT_API_KEY>
#   LLM_MODEL=<FPT_MODEL_ID>
#   LLM_BASE_URL=<FPT_OPENAI_COMPATIBLE_BASE_URL>
#
# NVIDIA (development):
#   LLM_PROVIDER=openai_like
#   LLM_API_KEY=<NVIDIA_API_KEY>
#   LLM_MODEL=deepseek-ai/deepseek-v4-pro
#   LLM_BASE_URL=https://integrate.api.nvidia.com/v1
#
# Anthropic (Claude, dùng llama-index-llms-anthropic riêng thay vì openai_like):
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=<ANTHROPIC_API_KEY>
#   LLM_MODEL=claude-sonnet-4-6
#   (bỏ trống LLM_BASE_URL)
# ---------------------------------------------------------------------------
