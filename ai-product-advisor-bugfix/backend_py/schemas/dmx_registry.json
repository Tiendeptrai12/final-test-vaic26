{
  "_note": "DMX real-data registry (products_detail.json). Top-level fields are shared across all 119 categories; spec maps are per-category and added as each category is ranked. Parsers reused from scripts/build_btc_catalog.py. No product data here — config only.",
  "source": "data/raw/dmx/products_detail.json (gitignored, NDA)",
  "top_level_mapping": {
    "product_id": "product_id",
    "tên sản phẩm": "name",
    "brand": "brand",
    "url_image": "image",
    "url": "url",
    "màu sắc": "color",
    "chính sách bảo hành": "warranty",
    "promotion": "promotion",
    "Phụ kiện đi kèm": "accessories",
    "rating_vote": {"key": "rating", "parser": "parse_rating"},
    "quantity_sold": {"key": "quantity_sold", "parser": "parse_quantity_sold"},
    "Giá gốc": {"key": "original_price", "parser": "price_to_int"},
    "Giá khuyến mãi": {"key": "promotion_price", "parser": "price_to_int"},
    "category_name": "category",
    "onlineSaleOnly": "online_sale_only"
  },
  "effective_price": "promotion_price if > 0 else original_price",
  "stock_status": "unknown (DMX data has no stock — never invented)",
  "categories": {
    "Máy lạnh": {
      "slug": "air_conditioner",
      "spec_map": {
        "Phạm vi làm lạnh hiệu quả": {"keys": ["area_min_m2", "area_max_m2"], "parser": "parse_area"},
        "Độ ồn trung bình (được đo trong phòng thí nghiệm)": {"keys": ["indoor_noise_min_db", "indoor_noise_max_db", "outdoor_noise_db"], "parser": "parse_noise"},
        "Công suất làm lạnh": {"keys": ["cooling_capacity_btu"], "parser": "parse_btu"},
        "Inverter": {"keys": ["inverter"], "parser": "parse_inverter"},
        "Dòng sản phẩm": {"keys": ["product_year"], "parser": "parse_year"},
        "Loại Gas": {"keys": ["gas"], "parser": "clean_str"},
        "Tiêu thụ điện": {"keys": ["power_kwh"], "parser": "parse_kwh"},
        "Công nghệ tiết kiệm điện": {"keys": ["energy_tech"], "parser": "clean_str"},
        "Loại máy": {"keys": ["machine_type"], "parser": "clean_str"}
      },
      "eligible_for_demo": "has effective_price AND parsed area",
      "note": "No CSPF / energy_stars in DMX data (unlike old Excel). Energy signal = power_kwh (lower better); ranking energy scoring updated in P4."
    }
  }
}
