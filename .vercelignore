# NDA + secrets — MUST never reach Vercel (belt-and-suspenders with .gitignore).
# Applies when deploying via `vercel` CLI (uploads working dir). Git-integration
# deploys only ship committed files, but keep this authoritative regardless.
.env
data/
artifacts/
*.xlsx

# Not needed at runtime (mock path) — slim the function bundle & cold start.
# frontend/ is owned & deployed separately by the teammate; this deploy is API-only.
frontend/
libs/
tests/
scripts/
schemas/
docs/
.claude/
/.agents/

# Local briefs / binaries — not part of the app.
*.docx
*.pdf
*.png
*.pptx
*.zip
FPT Factory API Key.txt
memory.md

# Python cruft
__pycache__/
*.py[cod]
.venv/
venv/
pytest.ini
