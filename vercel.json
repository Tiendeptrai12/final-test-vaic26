{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/css/:path*", "destination": "/frontend/css/:path*" },
    { "source": "/js/:path*", "destination": "/frontend/js/:path*" },
    { "source": "/img/:path*", "destination": "/frontend/img/:path*" },
    { "source": "/:file.:ext", "destination": "/frontend/:file.:ext" }
  ]
}

